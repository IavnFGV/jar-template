# Normalize line endings for text files
* text=auto

# Force LF for source and config files
*.java text eol=lf
*.gradle text eol=lf
*.properties text eol=lf
*.md text eol=lf
*.json text eol=lf
*.xml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.sh text eol=lf
*.bat text eol=crlf

# Keep binaries as binary
*.jar binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.zip binary
*.tar.gz binary
*.exe binary
